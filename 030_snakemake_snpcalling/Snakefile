# config & global variables
SAMPLES = ["TLE66_N", "TLE66_T"]
DB = "/staging/leuven/stg_00079/teaching/hg38_9/chr9.fa"
SNPEFF_JAR = "/lustre1/project/stg_00079/teaching/I0U19a_conda_2026/share/snpeff-5.4.0a-0/snpEff.jar"
SNPEFF_DB = "/staging/leuven/stg_00079/teaching/snpeff_db"

rule all:
    input:
        "100.final/snps.annotated.tsv",
	expand("010.fastqc/{sample}_fastqc.html", sample=SAMPLES)"

# fastqc quality control
rule fastqc:
    input:
        "{sample}.fastq"
    output:
        html="010.fastqc/{sample}_fastqc.html",
        zip="010.fastqc/{sample}_fastqc.zip"
    shell:
        """
        set -euo pipefail
        mkdir -p 010.fastqc
        
        fastqc {input} --outdir 010.fastqc/
        
        # Validation checks
        test -s {output.html}
        test -s {output.zip}
        """

# align & sort BAM

rule bwa_align:
    input:
        "{sample}.fastq"
    output:
        bam="020.bam/{sample}.bam",
        bai="020.bam/{sample}.bam.bai"
    threads: 4
    shell:
        """
        set -euo pipefail
        mkdir -p 020.bam
        
        bwa mem -t {threads} {DB} {input} | samtools sort -@ {threads} -o {output.bam} -
        samtools index {output.bam} {output.bai}
        
        # Validation checks
        test -s {output.bam}
        test -s {output.bai}
        samtools quickcheck {output.bam}
        """

# call raw SNPs

rule bcftools_calling:
    input:
        bam=expand("020.bam/{sample}.bam", sample=SAMPLES),
        bai=expand("020.bam/{sample}.bam.bai", sample=SAMPLES)
    output:
        raw_vcf="030.vcf/raw_snps.vcf"
    shell:
        """
        set -euo pipefail
        mkdir -p 030.vcf
        
        bcftools mpileup -Ou -f {DB} {input.bam} \
        | bcftools call -mv -Ov -o {output.raw_vcf}
        
        # Validation checks
        test -s {output.raw_vcf}
        grep -q "^#CHROM" {output.raw_vcf}
        """

#filter & clean SNPs

rule snp_filtering:
    input:
        raw_vcf="030.vcf/raw_snps.vcf"
    output:
        clean_vcf="040.clean_vcf/clean_snps.vcf"
    shell:
        """
        set -euo pipefail
        mkdir -p 040.clean_vcf
        
        cat {input.raw_vcf} \
        | vt decompose - \
        | vt normalize -n -r {DB} - \
        | vt uniq - \
        | vt view -f "QUAL>20" -h - \
        > {output.clean_vcf}
        
        # Validation checks
        test -s {output.clean_vcf}
        grep -q "^#CHROM" {output.clean_vcf}
        """

# annotate SNPs

rule snp_annotation:
    input:
        clean_vcf="040.clean_vcf/clean_snps.vcf"
    output:
        annotated_vcf="050.annotated_vcf/annotated_snps.vcf"
    shell:
        """
        set -euo pipefail
        mkdir -p 050.annotated_vcf
        
        # Note: Using hg38 since your reference DB is hg38_9/chr9.fa
        java -Xmx3400m -jar {SNPEFF_JAR} eff hg38 -dataDir {SNPEFF_DB} {input.clean_vcf} > {output.annotated_vcf}
        
        # Validation checks
        test -s {output.annotated_vcf}
        grep -q "^#CHROM" {output.annotated_vcf}
        """

# convert to final TSV

rule create_tsv:
    input:
        annotated_vcf="050.annotated_vcf/annotated_snps.vcf"
    output:
        "100.final/snps.annotated.tsv"
    shell:
        """
        set -euo pipefail
        mkdir -p 100.final
        
        # Create a clean header line first
        printf "CHROM\tPOS\tREF\tALT\tQUAL\tFILTER\tANN\n" > {output}
        
        # Append the data
        bcftools query -f '%CHROM\t%POS\t%REF\t%ALT\t%QUAL\t%FILTER\t%INFO/ANN\n' {input.annotated_vcf} >> {output}
        
        # Validation checks
        test -s {output}
        head -n 1 {output} | grep -q "CHROM"
        """
